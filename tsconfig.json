{
    "compilerOptions": {
        "baseUrl": ".",
        "paths": {
            "@/*": [
                "./frontend/src/*",
                "./src/*"
            ],
            "*": [
                "./frontend/node_modules/*"
            ]
        },
        "skipLibCheck": true,
        "module": "ESNext",
        "moduleResolution": "bundler",
        "allowJs": true,
        "esModuleInterop": true,
        "allowSyntheticDefaultImports": true,
        "strict": false,
        "resolveJsonModule": true
    },
    "include": [
        "frontend/src/**/*",
        "src/**/*",
        "frontend/node_modules/vite/client.d.ts"
    ],
    "exclude": [
        "node_modules",
        "frontend/node_modules"
    ]
}